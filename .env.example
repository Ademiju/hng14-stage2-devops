RESTART_POLICY=unless-stopped

INTERNAL_NETWORK_NAME=job-processing-internal
JOB_QUEUE=jobs

REDIS_IMAGE=redis:7-alpine
REDIS_APPENDONLY=yes
REDIS_PASSWORD=supersecretpassword123
REDIS_VOLUME_NAME=job-processing-redis-data
REDIS_CPUS=0.50
REDIS_MEMORY=256m
REDIS_HEALTHCHECK_INTERVAL=10s
REDIS_HEALTHCHECK_TIMEOUT=5s
REDIS_HEALTHCHECK_RETRIES=5
REDIS_HEALTHCHECK_START_PERIOD=10s

API_IMAGE=job-processing-api:latest
API_BUILD_CONTEXT=./api
API_DOCKERFILE=Dockerfile
API_REDIS_HOST=redis
API_REDIS_PORT=6379
API_HOST_PORT=8000
API_CONTAINER_PORT=8000
API_HEALTHCHECK_PATH=/health
API_CPUS=1.00
API_MEMORY=512m
API_HEALTHCHECK_INTERVAL=10s
API_HEALTHCHECK_TIMEOUT=5s
API_HEALTHCHECK_RETRIES=5
API_HEALTHCHECK_START_PERIOD=15s

WORKER_IMAGE=job-processing-worker:latest
WORKER_BUILD_CONTEXT=./worker
WORKER_DOCKERFILE=Dockerfile
WORKER_REDIS_HOST=redis
WORKER_REDIS_PORT=6379
WORKER_POLL_TIMEOUT=5
WORKER_JOB_DURATION_SECONDS=2
WORKER_CPUS=1.00
WORKER_MEMORY=512m
WORKER_HEALTHCHECK_INTERVAL=15s
WORKER_HEALTHCHECK_TIMEOUT=5s
WORKER_HEALTHCHECK_RETRIES=5
WORKER_HEALTHCHECK_START_PERIOD=15s

FRONTEND_IMAGE=job-processing-frontend:latest
FRONTEND_BUILD_CONTEXT=./frontend
FRONTEND_DOCKERFILE=Dockerfile
FRONTEND_API_URL=http://api:8000
FRONTEND_HOST=0.0.0.0
FRONTEND_HOST_PORT=3000
FRONTEND_CONTAINER_PORT=3000
FRONTEND_HEALTHCHECK_PATH=/health
FRONTEND_CPUS=0.75
FRONTEND_MEMORY=384m
FRONTEND_HEALTHCHECK_INTERVAL=10s
FRONTEND_HEALTHCHECK_TIMEOUT=5s
FRONTEND_HEALTHCHECK_RETRIES=5
FRONTEND_HEALTHCHECK_START_PERIOD=15s
